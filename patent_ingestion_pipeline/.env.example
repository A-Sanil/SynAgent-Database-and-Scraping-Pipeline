# Example .env for patent_ingestion_pipeline

# USB / portable storage root (raw/, parsed/, db/ created here)
# Windows example after running init-usb: PATENT_DATA_DIR=E:\synagent_patent_data
PATENT_DATA_DIR=
# UI credentials (optional). If set, UI requires login.
PATENT_UI_USER=your_username
PATENT_UI_PASS=your_password
# Secret used to sign login cookies. Keep private.
PATENT_UI_SECRET=some-long-random-secret

# Gemini configuration (Google API)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional legacy OpenAI-compatible endpoint if you use a proxy/server
PATENT_LLM_BASE_URL=
PATENT_LLM_MODEL=gemini-2.0-flash
PATENT_LLM_API_KEY=

# Autonomous agent (run-autonomous / SynAgentPatent.exe)
# PATENT_QUERIES_FILE=data/chemistry_queries.txt
# PATENT_COLLECT_LIMIT=8
# PATENT_PARSE_BATCH=5
# PATENT_COLLECT_SLEEP=120
# PATENT_AGENT_UI=1
